@page "/"
@rendermode InteractiveServer

<MudSnackbarProvider/>

<PageTitle>Tic-Tac-Toe</PageTitle>

<MudStack Spacing="3" Class="ma-2">
    <MudText Typo="Typo.body1">A classic two-player game. Take turns placing X and O on the board. Get three in a row to win!</MudText>

    <MudPaper Class="pa-4" Outlined="true" Style="max-width: 720px;">
        <MudText Typo="Typo.h5" Class="mb-2">Created Games</MudText>

        @if (_isLoadingGames)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" data-testid="home-games-loading" />
        }
        else if (_games.Count == 0)
        {
            <MudText Typo="Typo.body2" data-testid="home-games-empty">No games yet. Create one to get started.</MudText>
        }
        else
        {
            <table class="mud-table-root w-100" data-testid="home-games-list">
                <thead>
                    <tr>
                        <th class="text-left pa-2" data-testid="home-games-header-game-id">Game Id</th>
                        <th class="text-left pa-2" data-testid="home-games-header-status">Status</th>
                        <th class="text-left pa-2" data-testid="home-games-header-player">Player</th>
                        <th class="text-left pa-2" data-testid="home-games-header-created-at">Created</th>
                        <th class="text-left pa-2" data-testid="home-games-header-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var game in _games)
                    {
                        <tr data-testid="home-games-row">
                            <td class="pa-2">@game.GameId</td>
                            <td class="pa-2">@game.StatusLabel</td>
                            <td class="pa-2">@game.PlayerName</td>
                            <td class="pa-2">@game.CreatedAtLabel</td>
                            <td class="pa-2">
                                <MudLink Href="@($"/game/{game.GameId}")" data-testid="home-game-row-play-link">Play Game</MudLink>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="OnNewGame"
                   Disabled="@(_isLoadingGames || _isCreatingGame)"
                   Class="mt-4"
                   data-testid="home-new-game-button">
            New Game
        </MudButton>
    </MudPaper>
</MudStack>
