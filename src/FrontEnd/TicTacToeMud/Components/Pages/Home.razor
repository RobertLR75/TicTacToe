@page "/"
@rendermode InteractiveServer

<MudSnackbarProvider/>

<PageTitle>Tic-Tac-Toe</PageTitle>

<MudStack Spacing="3" Class="ma-2">
    <MudText Typo="Typo.h3" GutterBottom="true">Tic-Tac-Toe</MudText>
    <MudText Typo="Typo.body1">A classic two-player game. Take turns placing X and O on the board. Get three in a row to win!</MudText>

    <MudPaper Class="pa-4" Outlined="true" Style="max-width: 720px;">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.h5">Created Games</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="OnNewGame"
                       Disabled="@(_isLoadingGames || _isCreatingGame)"
                       data-testid="home-new-game-button">
                New Game
            </MudButton>
        </MudStack>

        @if (_isLoadingGames)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" data-testid="home-games-loading" />
        }
        else if (_games.Count == 0)
        {
            <MudText Typo="Typo.body2" data-testid="home-games-empty">No games yet. Create one to get started.</MudText>
        }
        else
        {
            <MudList T="string" Dense="true" data-testid="home-games-list">
                @foreach (var game in _games)
                {
                    <MudListItem T="string">
                        <MudText Typo="Typo.body2">
                            @game.GameId - @game.StatusLabel - @game.PlayerName - @game.CreatedAtLabel
                        </MudText>
                    </MudListItem>
                }
            </MudList>
        }
    </MudPaper>

    <MudButton Variant="Variant.Filled"
               Color="Color.Secondary"
               Size="Size.Large"
               Href="/game"
               StartIcon="@Icons.Material.Filled.SportsEsports"
               data-testid="home-play-game-button">
        Play Game
    </MudButton>
</MudStack>
