@page "/login"
@layout LoginLayout

<PageTitle>Login</PageTitle>

<div class="login-page-shell" data-testid="login-page">
    <MudContainer MaxWidth="MaxWidth.Small" Class="login-page">
        <MudPaper Class="login-panel pa-6 pa-sm-8" Outlined="true" Elevation="6">
            <MudStack Spacing="3">
                <MudStack Spacing="1" AlignItems="AlignItems.Start">
                    <MudChip T="string" Icon="@Icons.Material.Filled.DarkMode" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                        Tic-Tac-Toe
                    </MudChip>
                    <MudText Typo="Typo.h4" Class="login-title">Welcome Back</MudText>
                    <MudText Typo="Typo.body1" Class="login-subtitle">Sign in to continue to TicTacToe.</MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="login-error">
                        @ErrorMessage
                    </MudAlert>
                }

                <form class="login-form" method="post" action="/login/submit">
                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      Label="Username"
                                      Placeholder="Enter your username"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      InputId="name"
                                      InputType="InputType.Text"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Class="login-input-field"
                                      @bind-Value="_username" />

                        <input type="hidden" name="name" value="@_username" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   ButtonType="ButtonType.Submit"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Login"
                                   Class="login-submit-button">
                            Continue
                        </MudButton>
                    </MudStack>
                </form>
            </MudStack>
        </MudPaper>
    </MudContainer>
</div>

@code {
    private string _username = string.Empty;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }
}
