@page "/game"
@page "/game/{SelectedGameId}"
@rendermode InteractiveServer

<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<PageTitle>Tic-Tac-Toe</PageTitle>

<MudButton Variant="Variant.Text"
           Color="Color.Primary"
           Href="/"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           Class="mb-4"
           data-testid="game-back-home-button">
    Back to Home
</MudButton>

@if (_gameId is null)
{
    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mb-4" data-testid="game-no-selection-alert">
        No game selected. Create a game from Home, then open it to play.
    </MudAlert>
}

<MudText Typo="Typo.h5" Class="mb-4">@StatusMessage</MudText>

@if (_isOver && _showOutcomeBanner)
{
    <div class="@OutcomeOverlayClass" aria-hidden="true"></div>
    <MudPaper Class="@OutcomeAnimationClass" Outlined="true" data-testid="game-outcome-banner">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Class="outcome-content">
            <MudIcon Icon="@OutcomeIcon" Size="Size.Large" Class="outcome-icon" />
            <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="outcome-copy">
                <MudText Typo="Typo.h4" Align="Align.Center" Class="outcome-title">@OutcomeTitle</MudText>
                <MudText Typo="Typo.h6" Align="Align.Center" Class="outcome-subtitle">@OutcomeSubtitle</MudText>
            </MudStack>
            <img src="@OutcomeImageUrl" alt="@OutcomeImageAlt" class="outcome-image" />
        </MudStack>

        <div class="sparkles" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
    </MudPaper>
}

<MudGrid Spacing="1" Justify="Justify.FlexStart" Style="max-width: 420px;">
    @for (int row = 0; row < 3; row++)
    {
        var r = row;
        @for (int col = 0; col < 3; col++)
        {
            var c = col;
            <MudItem xs="4">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Large"
                           FullWidth="true"
                           Style="height: 124px; font-size: 2.5rem; font-weight: bold; min-width: 124px;"
                           Disabled="@IsCellDisabled(r, c)"
                           OnClick="@(() => OnCellClick(r, c))">
                    @GetCellDisplay(r, c)
                </MudButton>
            </MudItem>
        }
    }
</MudGrid>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" Style="max-width: 420px;" />
}

@if (GameHub.IsConnected)
{
    <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-2">Live</MudChip>
}
