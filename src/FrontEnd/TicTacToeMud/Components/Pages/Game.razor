@page "/game"
@rendermode InteractiveServer
@implements IAsyncDisposable

<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

@using TicTacToeMud.Services
@inject GameApiClient GameApi
@inject GameHubClient GameHub
@inject ISnackbar Snackbar

<PageTitle>Tic-Tac-Toe</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Tic-Tac-Toe</MudText>

<MudText Typo="Typo.h5" Class="mb-4">@StatusMessage</MudText>

<MudGrid Spacing="1" Justify="Justify.FlexStart" Style="max-width: 320px;">
    @for (int row = 0; row < 3; row++)
    {
        var r = row;
        @for (int col = 0; col < 3; col++)
        {
            var c = col;
            <MudItem xs="4">
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Large"
                           FullWidth="true"
                           Style="height: 90px; font-size: 2rem; font-weight: bold; min-width: 90px;"
                           Disabled="@IsCellDisabled(r, c)"
                           OnClick="@(() => OnCellClick(r, c))">
                    @GetCellDisplay(r, c)
                </MudButton>
            </MudItem>
        }
    }
</MudGrid>

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           Class="mt-4"
           OnClick="OnNewGame"
           Disabled="_isLoading">
    New Game
</MudButton>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" Style="max-width: 320px;" />
}

@if (GameHub.IsConnected)
{
    <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-2">Live</MudChip>
}

@code {
    private string?[,] _board = new string?[3, 3];
    private string? _gameId;
    private bool _isOver;
    private bool _isDraw;
    private string? _winner;
    private string? _currentPlayer;
    private bool _isLoading;

    private string StatusMessage
    {
        get
        {
            if (_gameId is null)
                return "Click \"New Game\" to start!";
            if (_isLoading)
                return "Loading...";
            if (_isDraw)
                return "It's a draw!";
            if (_winner is not null)
                return $"Player {_winner} wins!";
            return $"Player {_currentPlayer}'s turn";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ConnectToHub();
            await StartNewGame();
        }
    }

    private async Task ConnectToHub()
    {
        try
        {
            GameHub.OnGameStateUpdated += HandleGameStateUpdated;
            GameHub.OnGameStateInitialized += HandleGameStateInitialized;
            await GameHub.StartAsync();

            if (_gameId is not null)
            {
                await GameHub.JoinGame(_gameId);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to connect to game hub: {ex.Message}", Severity.Warning);
        }
    }

    private void HandleGameStateUpdated(TicTacToeMud.Models.GameResponse response)
    {
        if (response.GameId != _gameId) return;

        InvokeAsync(() =>
        {
            UpdateState(response);
            _isLoading = false;
            StateHasChanged();
        });
    }

    private void HandleGameStateInitialized(TicTacToeMud.Models.GameResponse response)
    {
        if (response.GameId != _gameId) return;

        InvokeAsync(() =>
        {
            UpdateState(response);
            _isLoading = false;
            StateHasChanged();
        });
    }

    private async Task StartNewGame()
    {
        _isLoading = true;
        try
        {
            // Leave previous game group
            if (_gameId is not null && GameHub.IsConnected)
            {
                await GameHub.LeaveGame(_gameId);
            }

            // Clear board state while waiting for notification
            _board = new string?[3, 3];
            _isOver = false;
            _isDraw = false;
            _winner = null;
            _currentPlayer = null;

            var gameId = await GameApi.CreateGameAsync();
            _gameId = gameId;

            // Allow the UI to be interactive immediately while we wait for state (hub or API)
            _isLoading = false;

            // Try to get initial state from API immediately so UI becomes interactive
            try
            {
                var state = await GameApi.GetGameAsync(gameId);
                if (state is not null)
                {
                    UpdateState(state);
                    _isLoading = false;
                }
            }
            catch
            {
                // Ignore - we'll wait for hub notification. UI is already enabled so user can interact.
            }

            // Join new game group for real-time updates
            if (GameHub.IsConnected)
            {
                await GameHub.JoinGame(gameId);
            }

            // State will also be populated by HandleGameStateInitialized when notification arrives
        }
        catch (Exception ex)
        {
            _isLoading = false;
            Snackbar.Add($"Failed to create game: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnNewGame()
    {
        await StartNewGame();
    }

    private async Task OnCellClick(int row, int col)
    {
        if (_gameId is null || _isOver || _board[row, col] is not null)
            return;

        _isLoading = true;
        try
        {
            await GameApi.MakeMoveAsync(_gameId, row, col);
            // State will be updated by HandleGameStateUpdated when notification arrives
        }
        catch (Exception ex)
        {
            _isLoading = false;
            Snackbar.Add($"Failed to make move: {ex.Message}", Severity.Error);
        }
    }

    private void UpdateState(TicTacToeMud.Models.GameResponse response)
    {
        _gameId = response.GameId;
        _isOver = response.IsOver;
        _isDraw = response.IsDraw;
        _winner = MarkToString(response.Winner);
        _currentPlayer = MarkToString(response.CurrentPlayer);

        _board = new string?[3, 3];
        foreach (var cell in response.Board)
        {
            _board[cell.Row, cell.Col] = MarkToString(cell.Mark);
        }
    }

    private static string? MarkToString(int mark) => mark switch
    {
        1 => "X",
        2 => "O",
        _ => null
    };

    private string GetCellDisplay(int row, int col)
    {
        return _board[row, col] ?? "\u00A0";
    }

    private bool IsCellDisabled(int row, int col)
    {
        return _isOver || _board[row, col] is not null || _gameId is null || _isLoading;
    }

    public async ValueTask DisposeAsync()
    {
        if (GameHub is not null)
        {
            GameHub.OnGameStateUpdated -= HandleGameStateUpdated;
            GameHub.OnGameStateInitialized -= HandleGameStateInitialized;

            if (_gameId is not null && GameHub.IsConnected)
            {
                await GameHub.LeaveGame(_gameId);
            }
        }
    }
}
