@namespace TicTacToeUI.Components.Board
@using TicTacToeUI.Components.Cell

<div class="board">
    @for (int row = 0; row < 3; row++)
    {
        <div class="board-row">
            @for (int col = 0; col < 3; col++)
            {
                var cell = State.Board.GetCell(row, col);
                <Cell CellData="@cell"
                      OnClick="@OnCellClick"
                      GameOver="@State.IsOver" />
            }
        </div>
    }
</div>

@code {
    [Parameter] public TicTacToeUI.Models.GameState State { get; set; } = default!;
    [Parameter] public EventCallback<TicTacToeUI.Models.Cell> OnCellClick { get; set; }
}
