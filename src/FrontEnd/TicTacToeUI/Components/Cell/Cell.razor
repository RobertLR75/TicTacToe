@namespace TicTacToeUI.Components.Cell

<button class="cell @GetCssClass()"
        @onclick="HandleClick"
        disabled="@IsDisabled">
    @GetMarkText()
</button>

@code {
    [Parameter] public TicTacToeUI.Models.Cell CellData { get; set; } = default!;
    [Parameter] public EventCallback<TicTacToeUI.Models.Cell> OnClick { get; set; }
    [Parameter] public bool GameOver { get; set; }

    private bool IsDisabled => CellData.Mark != TicTacToeUI.Models.PlayerMark.None || GameOver;

    private string GetMarkText() => CellData.Mark switch
    {
        TicTacToeUI.Models.PlayerMark.X => "X",
        TicTacToeUI.Models.PlayerMark.O => "O",
        _ => ""
    };

    private string GetCssClass() => CellData.Mark switch
    {
        TicTacToeUI.Models.PlayerMark.X => "cell-x",
        TicTacToeUI.Models.PlayerMark.O => "cell-o",
        _ => ""
    };

    private async Task HandleClick()
    {
        if (!IsDisabled)
            await OnClick.InvokeAsync(CellData);
    }
}
