@page "/"
@namespace TicTacToeUI.Pages.Game
@using TicTacToeUI.Components.Board
@inject TicTacToeUI.Services.GameService Game

<PageTitle>TicTacToe</PageTitle>

<div class="game-container">
    <h1>TicTacToe</h1>

    <div class="game-status">
        @if (Game.CurrentState.IsOver)
        {
            if (Game.CurrentState.IsDraw)
            {
                <span>It's a draw!</span>
            }
            else
            {
                <span>Player @Game.CurrentState.Winner wins!</span>
            }
        }
        else
        {
            <span>Player @Game.CurrentState.CurrentPlayer's turn</span>
        }
    </div>

    <Board State="@Game.CurrentState"
           OnCellClick="@HandleCellClick" />

    <button class="new-game-btn" @onclick="StartNewGame">New Game</button>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await StartNewGame();
    }

    private async Task HandleCellClick(TicTacToeUI.Models.Cell cell)
    {
        await Game.MakeMoveAsync(cell.Row, cell.Col);
        StateHasChanged();
    }

    private async Task StartNewGame()
    {
        await Game.StartNewGameAsync();
        StateHasChanged();
    }
}
